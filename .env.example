# MapLibre + OpenFreeMap does not require a map API key.

# Optional: enable FOUND CAT cloud backup and the public shared cat map.
# Leave these unset for local-only development.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Supabase publishable keys also work if your project uses the newer key naming.
VITE_SUPABASE_PUBLISHABLE_KEY=
